# ============================================================
# Gaolamthuy Admin - Environment Variables
# Copy this file to .env.local and fill in values
# VITE_* vars are injected at BUILD TIME only
# ============================================================

# ── Required ────────────────────────────────────────────────
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://ep-xxx.apirest.aws.neon.tech/neondb/rest/v1

# ── Node Environment ───────────────────────────────────────
NODE_ENV=production

# ── App Metadata (optional) ────────────────────────────────
VITE_APP_TITLE=Gao Lam Thuy Admin
# VITE_APP_VERSION=1.0.0

# ── n8n Webhook (optional) ────────────────────────────────
# VITE_N8N_WEBHOOK_URL=https://n8n.example.com/webhook
# VITE_N8N_WEBHOOK_BASIC_AUTH=username:password
# VITE_N8N_WEBHOOK_HEADER_KEY=
# VITE_N8N_WEBHOOK_HEADER_VALUE=

# ── Cloudinary - Client Upload (optional) ──────────────────
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_UPLOAD_PRESET=unsigned-preset
# VITE_CLOUDINARY_FOLDER=staging/products

# ── Cloudinary - Signed Upload (DEV ONLY, DO NOT use in prod)
# VITE_CLOUDINARY_API_KEY=
# VITE_CLOUDINARY_API_SECRET=
